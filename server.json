{
    "name":"hours.tracking",
    "debug":false,
    "trace":false,
    "openBrowser":true,
    "console":false,
    "trayEnable":false,
    "jvm":{
        "heapSize":2048,
        "minHeapSize":2048
    },
    "web":{
        "directoryBrowsing":true,
        "accessLogEnable":false,
        "maxRequests":30,
        "welcomeFiles":"index.cfm,index.html",
        "HTTP":{
            "host":"127.0.0.1",
            "enable":true,
            "port":"51717"
        },
        "ssl":{
            "enable":false
        },
        "rewrites":{
            "enable":true,
            "logEnable":true
        }
    },
    "app":{
        "cfengine":"lucee@6",
        "logDir":".logs",
        "sessionCookieSecure":true,
        "sessionCookieHTTPOnly":true
    },
    "fusionreactor":{
        "enable":false
    },
    "profile":"development"
}
