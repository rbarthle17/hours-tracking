    "CFMappings":{
        "/lucee-server/":{
            "archive":"",
            "inspectTemplate":"once",
            "listenerMode":"modern",
            "listenerType":"curr2root",
            "physical":"{lucee-server}/context/",
            "primary":"physical",
            "readonly":"yes"
        },
        "/lucee/":{
            "archive":"{lucee-config}/context/lucee-context.lar",
            "inspectTemplate":"once",
            "listenerMode":"modern",
            "listenerType":"curr2root",
            "physical":"{lucee-config}/context/",
            "primary":"physical",
            "readonly":"yes"
        },
        "/lucee/admin":{
            "archive":"{lucee-config}/context/lucee-admin.lar",
            "inspectTemplate":"once",
            "listenerMode":"curr2root",
            "listenerType":"modern",
            "physical":"{lucee-config}/context/admin",
            "primary":"physical",
            "readOnly":"true",
            "topLevel":"true"
        },
        "/lucee/doc":{
            "archive":"{lucee-config}/context/lucee-doc.lar",
            "inspectTemplate":"once",
            "listenerMode":"curr2root",
            "listenerType":"modern",
            "primary":"archive",
            "readOnly":"true",
            "topLevel":"true"
        }
    },
    "clientCookies":"true",
    "clientManagement":"false",
    "clientTimeout":"0,0,90,0",
    "componentPaths":{},
